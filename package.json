{
	"name": "@roastery-adapters/cache",
	"description": "Redis and in-memory cache adapter with safe error handling for the Roastery CMS ecosystem.",
	"version": "0.0.4",
	"type": "module",
	"author": {
		"name": "Alan Reis",
		"email": "alanreisanjo@gmail.com",
		"url": "https://github.com/Hoyasumii"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roastery-cms/adapters-cache"
	},
	"license": "MIT",
	"keywords": [
		"hoyasumii",
		"roastery",
		"roastery-adapters",
		"@roastery",
		"@roastery-adapters",
		"cache",
		"@roastery-adapters/cache",
		"roastery-adapters-cache"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*/index.d.ts"
			]
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js",
			"require": "./dist/*/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "biome check --fix && tsup 'src/**/index.ts' --format cjs,esm --dts --tsconfig tsconfig.build.json --clean --external bun",
		"test:unit": "bun test --env-file=.env.testing",
		"test:coverage": "bun test --env-file=.env.testing --coverage",
		"setup": "bun run build && bun link",
		"prepare": "husky || true",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"husky": "^9.1.7",
		"knip": "^5.85.0"
	},
	"peerDependencies": {
		"typescript": "^5.9.3",
		"@types/bun": "latest",
		"tsup": "^8.5.1",
		"@roastery/barista": "^0.0.5",
		"@roastery/terroir": "^0.0.9",
		"@roastery/beans": "^0.0.2"
	},
	"dependencies": {
		"ioredis-mock": "^8.13.1"
	}
}
